# ─── Asaas ───────────────────────────────────────────────────────────────────
# Copie sua API Key do painel Asaas: https://www.asaas.com/developerConfig
ASAAS_API_KEY=$aact_xxx...

# true = ambiente sandbox (testes), false = produção
ASAAS_SANDBOX=true

# Segredo para validar webhooks vindos do Asaas (crie uma string aleatória)
WEBHOOK_SECRET=troque-por-uma-string-aleatoria-secreta

# ─── Supabase ────────────────────────────────────────────────────────────────
# URL do seu projeto: Settings → API → Project URL
SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave service_role (NUNCA exponha no front-end!)
# Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000

# URL da área de membros (para o link de reset de senha)
MEMBERS_URL=https://membros.webcloneai.com.br

# Página onde o cliente define a senha (link enviado por e-mail após a compra)
# Precisa estar na allowlist do Supabase: Authentication → URL Configuration → Redirect URLs
PASSWORD_RESET_URL=https://webcloneai.com.br/redefinir-senha

# Origens permitidas no CORS (separe por vírgula)
ALLOWED_ORIGINS=https://webcloneai.com.br,https://www.webcloneai.com.br,https://membros.webcloneai.com.br
